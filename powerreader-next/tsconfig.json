{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"noEmit": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["@webgpu/types"]
	},
	"include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
