{
  "name": "powerreader",
  "version": "0.1.0",
  "description": "PowerReader - Taiwan News Bias Analysis System (Cloudflare Workers)",
  "type": "module",
  "main": "src/workers/index.js",
  "scripts": {
    "dev": "wrangler dev --local",
    "build": "npm run build:pages && npm run build:worker",
    "build:pages": "echo 'Pages build placeholder'",
    "build:worker": "echo 'Worker build placeholder'",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "lint": "eslint src/ shared/ scripts/",
    "lint:fix": "eslint src/ shared/ scripts/ --fix",
    "test": "npx jest --config jest.config.cjs --passWithNoTests",
    "test:integration": "npx jest --config jest.integration.config.cjs --passWithNoTests",
    "test:coverage": "npx jest --config jest.config.cjs --coverage --passWithNoTests",
    "validate": "node scripts/validate-config.js && node scripts/validate-enums.js && node scripts/validate-state-machine.js",
    "security:patterns": "node scripts/security-patterns.js",
    "precommit": "npm run lint && npm run validate && npm test"
  },
  "keywords": [
    "taiwan",
    "news",
    "bias-analysis",
    "cloudflare-workers",
    "pwa"
  ],
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.71.0"
  }
}
